{
  "name": "picopals-8bit",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:rules:unit": "vitest run src/tests/firestore.rules.test.ts --environment node",
    "test:rules": "firebase emulators:exec --only firestore --project picopals-local-test \"npm.cmd run test:rules:unit\"",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "firebase": "firebase"
  },
  "dependencies": {
    "dexie": "^4.0.11",
    "firebase": "^12.8.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "fake-indexeddb": "^6.2.2",
    "firebase-tools": "^14.27.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
